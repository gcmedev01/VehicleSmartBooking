@model VehicleSmartBooking.Features.Dashboard.Widgets.Kpis.KpiCardsVm

<div class="row g-3">
    @foreach (var item in Model.Items)
    {
        <div class="col-6 col-lg-4">
            <a class="text-decoration-none" href="@(item.Href ?? "#")">
                <div class="border rounded p-3 h-100 bg-light">
                    <div class="d-flex align-items-center gap-2 text-muted small">
                        @if (!string.IsNullOrWhiteSpace(item.IconClass))
                        {
                            <i class="@item.IconClass"></i>
                        }
                        <span>@item.Title</span>
                    </div>
                    <div class="fs-4 fw-semibold text-dark">@item.ValueText</div>
                    @if (!string.IsNullOrWhiteSpace(item.Subtitle))
                    {
                        <div class="text-muted small">@item.Subtitle</div>
                    }
                </div>
            </a>
        </div>
    }
</div>
