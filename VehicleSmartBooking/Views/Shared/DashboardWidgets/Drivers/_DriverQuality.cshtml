@model VehicleSmartBooking.Features.Dashboard.Widgets.Drivers.DriverQualityVm

@{
    var ratingUrl = Url.Action("RatingDistData", "AdminDashboard") ?? string.Empty;
    var outcomeUrl = Url.Action("DispatchOutcomeData", "AdminDashboard") ?? string.Empty;
}

<div class="row g-3">
    <div class="col-12">
        <div class="fw-semibold mb-2">Rating Distribution</div>
        <div class="d-flex flex-wrap align-items-center gap-3 mb-2 text-muted">
            <span>Avg Rating: <strong class="js-rating-avg">0.0</strong></span>
            <span>Ratings: <strong class="js-rating-count">0</strong></span>
        </div>
        <div class="dashboard-chart">
            <canvas class="js-rating-dist-chart" data-rating-url="@ratingUrl"></canvas>
        </div>
    </div>
    <div class="col-12">
        <div class="fw-semibold mb-2">Dispatch Outcomes</div>
        <div class="dashboard-chart">
            <canvas class="js-dispatch-outcome-chart" data-outcome-url="@outcomeUrl"></canvas>
        </div>
        <div class="mt-3">
            <div class="fw-semibold mb-2">Top Decline Reasons</div>
            <ul class="list-unstyled mb-0 js-decline-reasons text-muted small"></ul>
        </div>
    </div>
    <div class="col-12">
        <div class="fw-semibold mb-2">Top Drivers</div>
        @if (Model.TopDrivers.Count == 0)
        {
            <div class="text-muted">No driver data.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted">
                            <th>Driver</th>
                            <th class="text-end">Trips</th>
                            <th class="text-end">Avg Rating</th>
                            <th class="text-end">Accept Rate</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var driver in Model.TopDrivers)
                        {
                            <tr>
                                <td>@driver.DriverName</td>
                                <td class="text-end">@driver.Trips</td>
                                <td class="text-end">@driver.AverageRating.ToString("0.0")</td>
                                <td class="text-end">@driver.AcceptRate.ToString("P0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
