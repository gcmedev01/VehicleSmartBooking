@using System.Security.Claims
@{
    // =========================================================
    // Active nav (controller/action fallback)
    // =========================================================
    var active = (ViewData["ActiveNav"] as string) ?? "";

    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();

    if (string.IsNullOrEmpty(active))
    {
        // Booking
        if (controller == "booking" && action == "create") active = "MyRequest";
        else if (controller == "booking" && (action == "mybookings" || action == "detail")) active = "MyTask";

        // Approvals
        else if (controller == "approvals" && action == "pending") active = "Approve";
        else if (controller == "approvals" && action == "history") active = "ApproveHistory";
        else if (controller == "approvals" && action == "detail") active = "Approve";

        // Admin
        else if (controller == "admin" && action == "worklist") active = "AdminWorklist";
        else if (controller == "admin" && (action == "allbookings" || action == "detail")) active = "AllTasks";
        else if (controller == "admin" && action == "booking") active = "AdminWorklist";
        else if (controller == "admin" && action == "queue") active = "Queue";
        else if (controller == "admin" && action == "vehicles") active = "AdminVehicles";
        else if (controller == "admin" && action == "vehiclecreate") active = "AdminVehicles";
        else if (controller == "admin" && action == "vehicleedit") active = "AdminVehicles";
        else if (controller == "admin" && action == "drivers") active = "AdminDrivers";
        else if (controller == "admin" && action == "editdriver") active = "AdminDrivers";
        else if (controller == "admin" && action == "createdriver") active = "AdminDrivers";
        else if (controller == "admin" && action == "users") active = "AdminUsers";
        else if (controller == "admin" && action == "createapprover") active = "AdminUsers";

        // Driver
        else if (controller == "driver" && (action == "myjobs" || action == "detail")) active = "DriverJobs";

        // Notifications / Help
        else if (controller == "notifications") active = "Notifications";
        else if (controller == "help") active = "DriverGuide";

        else active = "MyTask";
    }

    // =========================================================
    // Role checks (from ClaimsFactory -> ClaimTypes.Role)
    // =========================================================
    var isUser = User.IsInRole("User");
    var isApprover = User.IsInRole("Approver");
    var isAdmin = User.IsInRole("Admin");
    var isDriver = User.IsInRole("Driver");

    // Business rule:
    // - Driver "cannot book" / "cannot view queue" if driver-only.
    // - If user has other roles too (User/Approver/Admin) => allow booking pages.
    var canBook = isUser || isApprover || isAdmin;
    var canSeeApprovals = isApprover || isAdmin; // admin can help approve if you want
    var canSeeAdmin = isAdmin;

    // =========================================================
    // Resolve display name + user code
    // =========================================================
    var usernameEn = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "";
    var userCode = User.FindFirst("UserCode")?.Value
                   ?? User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                   ?? "";

    // =========================================================
    // Central support team contacts
    // TODO: แก้เป็นข้อมูลจริงของทีม support (ชื่อ / เบอร์ / อีเมล)
    // =========================================================
    var supportContacts = new[]
    {
        new { Name = "คุณ ศุธาสิณี มณีวรรณ", Phone = "78842", Email = "zSuthasinee.M@pttgcgroup.com" },
        new { Name = "คุณพรทิพย์ ลิ้มถาวร", Phone = "78843", Email = "Porntip.L@pttgcgroup.com" },
        new { Name = "คุณอรนุช สุขมั่น", Phone = "78841", Email = "ORANUT.S@pttgcgroup.com" },
    };

    // Build initials: ignore common prefixes like "Mr."
    string GetInitials(string full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "";
        var prefixes = new[] { "mr", "mr.", "mrs", "mrs.", "miss", "miss." };
        var parts = full.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                        .Where(p => !prefixes.Contains(p.TrimEnd('.').ToLowerInvariant()))
                        .ToArray();
        if (parts.Length == 0) return "";
        if (parts.Length == 1)
        {
            var p = parts[0];
            return p.Length >= 2 ? p.Substring(0, 2).ToUpperInvariant() : p.Substring(0, 1).ToUpperInvariant();
        }
        var first = parts.First()[0];
        var last = parts.Last()[0];
        return (char.ToUpperInvariant(first).ToString() + char.ToUpperInvariant(last).ToString());
    }

    string GetShortName(string full)
    {
        if (string.IsNullOrWhiteSpace(full)) return "";
        var prefixes = new[] { "mr", "mr.", "mrs", "mrs.", "miss", "miss." };
        var parts = full.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                        .Where(p => !prefixes.Contains(p.TrimEnd('.').ToLowerInvariant()))
                        .ToArray();
        if (parts.Length == 0) return full;
        if (parts.Length == 1) return parts[0];
        return parts[0] + " " + parts.Last().Substring(0, 1) + ".";
    }

    var initials = GetInitials(usernameEn);
    var shortName = GetShortName(usernameEn);

    string RoleBadgeText()
    {
        // show priority-ish: Admin > Approver > Driver > User
        if (isAdmin) return "Admin";
        if (isApprover) return "Approver";
        if (isDriver) return "Driver";
        if (isUser) return "User";
        return "User";
    }
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - VehicleSmartBooking</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Thai:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true" />
    <link href="~/lib/bootstrap-icons-1.13.1/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/vehicle-booking.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0d6efd" />
    <!-- iOS Add-to-Home-Screen / standalone PWA hints (required for Web Push on iPhone) -->
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Vehicle Booking" />
    <link rel="apple-touch-icon" href="/img/van.png" />
    <script>
        // Restore desktop sidebar collapsed state before first paint (avoids flicker)
        (function () {
            try {
                if (localStorage.getItem('vbSidebarCollapsed') === '1') {
                    document.documentElement.classList.add('vb-sidebar-collapsed');
                }
            } catch (e) { }
        })();
    </script>

    @RenderSection("Styles", required: false)
</head>

<body class="vb-body">

    <!-- Topbar (mobile) -->
    <header class="vb-topbar d-md-none border-bottom bg-white">
        <div class="container-fluid py-2 d-flex align-items-center gap-2">
            <button class="btn btn-outline-secondary btn-sm" type="button"
                    data-bs-toggle="offcanvas" data-bs-target="#vbSidebar" aria-controls="vbSidebar">
                ☰
            </button>
            <div class="vb-brand d-flex align-items-center gap-2">
                <div class="vb-logo">VB</div>
                <div class="fw-semibold">Vehicle Booking</div>
            </div>
        </div>
    </header>

    <div class="vb-shell">
        <!-- Sidebar -->
        <aside class="vb-sidebar offcanvas offcanvas-md offcanvas-start" tabindex="-1" id="vbSidebar" aria-labelledby="vbSidebarLabel">
             <div class="vb-sidebar-inner">
                  <div class="vb-sidebar-header">
                    <div class="vb-brand d-flex align-items-center gap-2">
                        <div class="vb-logo">VB</div>
                        <div>
                            <div class="fw-semibold">Vehicle Booking</div>
                            <div class="text-muted small">ระบบจองรถ</div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-light vb-sidebar-collapse-btn ms-auto"
                            id="vbSidebarCollapseBtn" title="ย่อเมนู" aria-label="ย่อเมนู" aria-expanded="true">
                        <i class="bi bi-chevron-double-left"></i>
                    </button>
                    <button type="button" class="btn-close d-md-none" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                 </div>

                <nav class="vb-nav">
                    @* ========= Requester pages (User/Approver/Admin) ========= *@
                    @if (canBook)
                    {
                        <div class="vb-nav-section">
                            <div class="vb-nav-label">REQUEST</div>

                            <a asp-controller="Booking" asp-action="Create"
                               class="vb-nav-item @(active == "MyRequest" ? "is-active" : "")"
                               aria-current="@(active == "MyRequest" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-plus-circle"></i></span>
                                New Request
                            </a>

                            <a asp-controller="Booking" asp-action="MyBookings"
                               class="vb-nav-item @(active == "MyTask" ? "is-active" : "")"
                               aria-current="@(active == "MyTask" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-briefcase"></i></span>
                                My Task
                            </a>
                        </div>
                    }

                    @* ========= Approver ========= *@
                    @if (canSeeApprovals)
                    {
                        <div class="vb-nav-section">
                            <div class="vb-nav-label">APPROVAL</div>

                            <a asp-controller="Approvals" asp-action="Pending"
                               class="vb-nav-item @(active == "Approve" ? "is-active" : "")"
                               aria-current="@(active == "Approve" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-check2-square"></i></span>
                                Pending Approvals
                            </a>

                            <a asp-controller="Approvals" asp-action="History"
                               class="vb-nav-item @(active == "ApproveHistory" ? "is-active" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-clock-history"></i></span>
                                Approval History
                            </a>
                        </div>
                    }

                    @* ========= Admin ========= *@
                    @if (canSeeAdmin)
                    {
                        <div class="vb-nav-section">
                            <div class="vb-nav-label">ADMIN</div>

                            <a asp-controller="AdminDashboard" asp-action="Index"
                               class="vb-nav-item @(active == "Dashboard" ? "is-active" : "")"
                               aria-current="@(active == "Dashboard" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-speedometer2"></i></span>
                                Dashboard
                            </a>

                            <a asp-controller="Admin" asp-action="Worklist"
                               class="vb-nav-item @(active == "AdminWorklist" ? "is-active" : "")"
                               aria-current="@(active == "AdminWorklist" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-list-check"></i></span>
                                Admin Worklist
                                <span class="ms-auto badge rounded-pill bg-danger d-none"
                                      data-worklist-badge
                                      style="font-size:.7rem;padding:3px 6px;line-height:1;"></span>
                            </a>

                            <a asp-controller="Admin" asp-action="AllBookings"
                               class="vb-nav-item @(active == "AllTasks" ? "is-active" : "")"
                               aria-current="@(active == "AllTasks" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-briefcase"></i></span>
                                All Tasks
                            </a>

                            <a asp-controller="Admin" asp-action="Queue"
                               class="vb-nav-item @(active == "Queue" ? "is-active" : "")"
                               aria-current="@(active == "Queue" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-calendar3"></i></span>
                                Queue
                            </a>

                            <a asp-controller="Admin" asp-action="Vehicles" class="vb-nav-item @(active == "AdminVehicles" ? "is-active" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-truck"></i></span>
                                Vehicles
                            </a>

                            <a asp-controller="Admin" asp-action="Drivers" class="vb-nav-item @(active == "AdminDrivers" ? "is-active" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-person-badge"></i></span>
                                Drivers
                            </a>

                            <a asp-controller="Admin" asp-action="Users" class="vb-nav-item @(active == "AdminUsers" ? "is-active" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-people"></i></span>
                                Users & Roles
                            </a>
                        </div>
                    }

                    @* ========= Notifications (all logged-in users) ========= *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="vb-nav-section">
                            <div class="vb-nav-label">NOTIFICATIONS</div>
                            <a asp-controller="Notifications" asp-action="Index"
                               class="vb-nav-item @(active == "Notifications" ? "is-active" : "")"
                               aria-current="@(active == "Notifications" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-bell"></i></span>
                                การแจ้งเตือน
                                <span class="ms-auto badge rounded-pill bg-danger d-none"
                                      data-notification-badge
                                      style="font-size:.7rem;padding:3px 6px;line-height:1;"></span>
                            </a>
                        </div>
                    }

                    @* ========= Driver ========= *@
                    @if (isDriver)
                    {
                        <div class="vb-nav-section">
                            <div class="vb-nav-label">DRIVER</div>

                            <a asp-controller="Driver" asp-action="MyJobs"
                               class="vb-nav-item @(active == "DriverJobs" ? "is-active" : "")"
                               aria-current="@(active == "DriverJobs" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-steering-wheel"></i></span>
                                My Jobs
                            </a>

                            <a asp-controller="Help" asp-action="DriverNotificationGuide"
                               class="vb-nav-item @(active == "DriverGuide" ? "is-active" : "")"
                               aria-current="@(active == "DriverGuide" ? "page" : "")">
                                <span class="vb-nav-icon"><i class="bi bi-phone"></i></span>
                                คู่มือการแจ้งเตือน
                            </a>
                        </div>
                    }

                    @* ========= Support / contact ========= *@
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="vb-nav-section">
                            <div class="vb-nav-label">Cantact</div>
                            <div class="vb-nav-help px-2 py-2 small text-muted">
                                <div class="mb-2">หากมีข้อสงสัยหรือพบปัญหา ติดต่อ:</div>
                                @foreach (var c in supportContacts)
                                {
                                    <div class="mb-2">
                                        <div class="fw-semibold text-dark">
                                            <i class="bi bi-person-circle me-1"></i>@c.Name
                                        </div>
                                        <div>
                                            <i class="bi bi-telephone me-1"></i>
                                            @c.Phone
                                        </div>
                                        <div class="text-break">
                                            <i class="bi bi-envelope me-1"></i>
                                            @c.Email
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </nav>

                <div class="vb-sidebar-footer">
                    <div class="d-flex align-items-center gap-2">
                        <div class="vb-logo" title="@usernameEn">@initials</div>

                        <div class="flex-grow-1">
                            <div class="fw-semibold d-flex align-items-center gap-2" style="font-size:.95rem;">
                                <span>@shortName</span>
                                <span class="badge text-bg-light border" style="font-weight:600;">@RoleBadgeText()</span>
                            </div>
                            <div class="text-muted small">@userCode</div>
                        </div>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary position-relative"
                                        type="button"
                                        id="notifBellBtn"
                                        data-bs-toggle="dropdown"
                                        data-bs-auto-close="outside"
                                        aria-expanded="false"
                                        title="การแจ้งเตือน">
                                    <i class="bi bi-bell"></i>
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none"
                                          data-notification-badge
                                          style="font-size:.6rem;padding:2px 5px;line-height:1.2;"></span>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end shadow-sm p-0"
                                     style="min-width:300px;max-width:360px;"
                                     aria-labelledby="notifBellBtn">
                                    <div class="d-flex justify-content-between align-items-center px-3 py-2 border-bottom">
                                        <span class="fw-semibold small">การแจ้งเตือน</span>
                                        <a asp-controller="Notifications" asp-action="Index" class="small text-primary">ดูทั้งหมด</a>
                                    </div>
                                    <div id="notifDropdownItems" style="max-height:320px;overflow-y:auto;">
                                        <div class="text-center py-3 text-muted small">กำลังโหลด...</div>
                                    </div>
                                </div>
                            </div>
                        }

                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Log out">
                                <i class="bi bi-box-arrow-right"></i>
                            </button>
                        </form>
                    </div>
                </div>
             </div>
         </aside>

        <!-- Reopen button (desktop, visible only when sidebar is collapsed) -->
        <button type="button" class="btn btn-primary vb-sidebar-reopen-btn"
                id="vbSidebarReopenBtn" title="เปิดเมนู" aria-label="เปิดเมนู">
            <i class="bi bi-list"></i>
        </button>

        <!-- Main -->
        <main class="vb-main">
            <div class="vb-main-inner">
                @RenderBody()
            </div>
        </main>
    </div>
    <script>
        window.appBasePath = "@Url.Content("~/")";
    </script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
    // Desktop sidebar collapse/expand toggle (persisted in localStorage)
    (function () {
        var KEY = 'vbSidebarCollapsed';
        var root = document.documentElement;
        var collapseBtn = document.getElementById('vbSidebarCollapseBtn');
        var reopenBtn = document.getElementById('vbSidebarReopenBtn');

        function setCollapsed(collapsed) {
            root.classList.toggle('vb-sidebar-collapsed', collapsed);
            try { localStorage.setItem(KEY, collapsed ? '1' : '0'); } catch (e) { }
            if (collapseBtn) collapseBtn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        }

        if (collapseBtn) collapseBtn.addEventListener('click', function () { setCollapsed(true); });
        if (reopenBtn) reopenBtn.addEventListener('click', function () { setCollapsed(false); });

        // Reflect the state restored by the head script on the toggle button
        if (collapseBtn && root.classList.contains('vb-sidebar-collapsed')) {
            collapseBtn.setAttribute('aria-expanded', 'false');
        }
    })();
    </script>
    <script>
    // Register service worker for PWA Web Push (HTTPS / localhost only)
    if ('serviceWorker' in navigator
        && (location.protocol === 'https:' || location.hostname === 'localhost' || location.hostname === '127.0.0.1')) {
        navigator.serviceWorker.register('/service-worker.js')
            .catch(function (err) { console.warn('[SW] Registration failed:', err); });
    }
    </script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>
        (function () {
            // ── Badge helpers ─────────────────────────────────────────────
            function updateBadges(count) {
                var badges = document.querySelectorAll('[data-notification-badge]');
                var text = count > 99 ? '99+' : String(count);
                badges.forEach(function (el) {
                    if (count > 0) {
                        el.textContent = text;
                        el.classList.remove('d-none');
                    } else {
                        el.classList.add('d-none');
                    }
                });
            }

            // Exposed globally so any page script can trigger a refresh
            window.refreshNotifBadges = function () {
                fetch('/Notifications/GetUnreadCount', { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (d) { if (d) updateBadges(d.count); })
                    .catch(function (e) { console.warn('[Notif] Failed to fetch unread count', e); });
            };

            // Fetch count on initial page load
            window.refreshNotifBadges();

            // ── Admin Worklist badge ──────────────────────────────────────
            // Only present in the DOM for admins, so this is a no-op for other roles.
            var worklistBadge = document.querySelector('[data-worklist-badge]');
            if (worklistBadge) {
                fetch('/Admin/WorklistCount', { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (d) {
                        if (!d) return;
                        var text = d.count > 99 ? '99+' : String(d.count);
                        if (d.count > 0) {
                            worklistBadge.textContent = text;
                            worklistBadge.classList.remove('d-none');
                        } else {
                            worklistBadge.classList.add('d-none');
                        }
                    })
                    .catch(function (e) { console.warn('[Worklist] Failed to fetch count', e); });
            }

            // ── Bell dropdown ─────────────────────────────────────────────
            var bell = document.getElementById('notifBellBtn');
            if (!bell) return;

            // Reload dropdown items every time it opens (shows fresh data)
            bell.addEventListener('shown.bs.dropdown', function () {
                loadRecent();
            });

            function loadRecent() {
                var container = document.getElementById('notifDropdownItems');
                if (!container) return;
                container.innerHTML = '<div class="text-center py-2 text-muted small">กำลังโหลด...</div>';

                fetch('/Notifications/GetRecent', { credentials: 'same-origin' })
                    .then(function (r) { return r.ok ? r.json() : null; })
                    .then(function (d) {
                        if (!d || !d.items || d.items.length === 0) {
                            container.innerHTML = '<div class="text-center py-3 text-muted small">ไม่มีการแจ้งเตือน</div>';
                            return;
                        }
                        container.innerHTML = d.items.map(function (n) {
                            var bg = n.isRead ? '' : 'bg-light';
                            var fw = n.isRead ? '' : 'fw-semibold';
                            var dt = '';
                            if (n.createdAtUtc) {
                                try { dt = new Date(n.createdAtUtc).toLocaleString('th-TH', { dateStyle: 'short', timeStyle: 'short' }); }
                                catch (e) { dt = ''; }
                            }
                            return '<a href="' + (window.appBasePath || "/") + 'Notifications/MarkReadAndRedirect/' + n.notificationId + '"'
                                + ' class="d-block text-decoration-none text-dark border-bottom px-3 py-2 ' + bg + '">'
                                + '<div class="small ' + fw + '">' + esc(n.title) + '</div>'
                                + '<div class="text-muted" style="font-size:.8rem;white-space:normal;">' + esc(n.message) + '</div>'
                                + (dt ? '<div class="text-muted" style="font-size:.75rem;">' + dt + '</div>' : '')
                                + '</a>';
                        }).join('');
                    })
                    .catch(function (e) {
                        console.warn('[Notif] Failed to load recent notifications', e);
                        if (container) container.innerHTML = '<div class="text-center py-3 text-muted small">โหลดไม่สำเร็จ</div>';
                    });
            }

            function esc(s) {
                if (!s) return '';
                var el = document.createElement('div');
                el.textContent = s;
                return el.innerHTML;
            }
        })();
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
