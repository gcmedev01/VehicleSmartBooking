@{
    ViewData["Title"] = "Sign In";
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <div class="auth-shell" id="authShell">
        <div class="auth-grid">

            <!-- LEFT: Sign In -->
            <section class="pane pane-signin">
                <div class="brand-row">
                    <span class="brand-dot"></span>
                    <span class="brand-name">VehicleSmartBooking</span>
                </div>

                <h2 class="mb-2">Sign In</h2>
                <div class="text-muted2 mb-4">Choose how you want to sign in</div>

                <!-- Choice 1: Microsoft -->
                <a class="choice-card d-flex gap-3 align-items-center text-decoration-none text-dark mb-3" href="/auth/sso/login">
                    <div class="choice-icon choice-icon-ms">
                        <svg width="22" height="22" viewBox="0 0 23 23" aria-hidden="true">
                            <rect x="0" y="0" width="10" height="10" fill="#F25022" />
                            <rect x="13" y="0" width="10" height="10" fill="#7FBA00" />
                            <rect x="0" y="13" width="10" height="10" fill="#00A4EF" />
                            <rect x="13" y="13" width="10" height="10" fill="#FFB900" />
                        </svg>
                    </div>
                    <div class="flex-grow-1 sso-login">
                        <div class="fw-semibold">Sign in with Microsoft Online</div>
                        <div class="text-muted2 small">SSO / Azure AD</div>
                    </div>
                    <div class="text-muted2">›</div>
                </a>

                <!-- Choice 2: Username/Password -->
                <button type="button" class="choice-card w-100 text-start d-flex gap-3 align-items-center mb-2"
                        id="toggleLocal">
                    <div class="choice-icon choice-icon-alt">
                        <i class="bi bi-person-lock"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="fw-semibold">Use username &amp; password</div>
                        <div class="text-muted2 small">Local account</div>
                    </div>
                    <div class="text-muted2" id="localChevron">›</div>
                </button>

                <!-- Local login form (ยังอยู่หน้าเดิม แค่โผล่ขึ้นมา) -->
                <div class="local-form" id="localForm">
                    <form asp-controller="Account" asp-action="Login" method="post" class="mt-3">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label small text-muted2">Username</label>
                            <input name="Username" class="form-control" autocomplete="username" />
                        </div>

                        <div class="mb-2">
                            <label class="form-label small text-muted2">Password</label>
                            <input name="Password" type="password" class="form-control" autocomplete="current-password" />
                        </div>

                        <div class="d-flex justify-content-between align-items-center my-3">
                            <a class="small text-decoration-none" asp-controller="Account" asp-action="ForgotPassword">
                                Forgot your password?
                            </a>
                            <button class="btn btn-primary btn-pill px-4" type="submit">Sign In</button>
                        </div>
                    </form>
                </div>

                <hr class="my-4" />

                <!-- Sign up trigger -->
                <div class="d-flex align-items-center justify-content-between">
                    <div class="text-muted2 small">Don’t have an account?</div>
                    <button class="btn btn-outline-dark btn-pill px-4" type="button" id="goSignup">
                        Sign up
                    </button>
                </div>
            </section>

            <!-- RIGHT: Create Account -->
            <section class="pane pane-signup">
                <h2 class="mb-2">Create Account</h2>
                <div class="text-muted2 mb-4">Register with your email for local account</div>

                <form asp-controller="Account" asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label small text-muted2">Name</label>
                        <input name="Name" class="form-control" autocomplete="name" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted2">Email</label>
                        <input name="Email" type="email" class="form-control" autocomplete="email" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small text-muted2">Password</label>
                        <input name="Password" type="password" class="form-control" autocomplete="new-password" />
                    </div>

                    <button class="btn btn-primary btn-pill px-4" type="submit">Sign Up</button>
                </form>

                <div class="mt-4">
                    <button class="btn btn-link text-decoration-none p-0" type="button" id="backToLogin">
                        ← Back to Sign In
                    </button>
                </div>
            </section>
        </div>

        <!-- Overlay (แผงสีโค้ง) -->
        <aside class="overlay">
            <div class="overlay-inner">
                <h3 id="overlayTitle">Hello, Friend!</h3>
                <p class="mb-3" id="overlayText">
                    Register with your personal details to use all of site features
                </p>

                <button class="btn btn-outline-light btn-pill px-4" type="button" id="overlayBtn">
                    SIGN UP
                </button>
            </div>
        </aside>
    </div>
</div>

<div class="modal fade" id="loginErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">เข้าสู่ระบบไม่สำเร็จ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                @Html.ValidationSummary(excludePropertyErrors: true)
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-primary" data-bs-dismiss="modal">ตกลง</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @if (!ViewData.ModelState.IsValid)
    {
        <script>
            (() => {
                const localForm = document.getElementById("localForm");
                const localChevron = document.getElementById("localChevron");
                if (localForm && !localForm.classList.contains("is-open")) {
                    localForm.classList.add("is-open");
                    if (localChevron) localChevron.textContent = "⌄";
                }

                const modalEl = document.getElementById("loginErrorModal");
                if (!modalEl) return;
                const modal = new bootstrap.Modal(modalEl);
                modal.show();
            })();
        </script>
    }
}
