@{
    ViewData["Title"] = "Home";
}

<section id="home" class="hero">
    <div class="hero-wave" aria-hidden="true"></div>

    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <h1 class="display-5 fw-bold lh-sm mb-3">
                    Online Vehicle<br />Smart Booking
                </h1>
                <p class="lead text-muted2 mb-4">
                    จองรถองค์กร/ทีมงานแบบเรียลไทม์ พร้อม Approval Flow และรายงานการใช้งาน
                </p>

                <div class="d-flex flex-wrap gap-2" id="get-started">
                    <a class="btn btn-primary btn-lg btn-pill px-4" href="#contact">Get Started</a>
                    <a class="btn btn-outline-dark btn-lg btn-pill px-4" href="#features">More Info</a>
                </div>
            </div>

            <div class="col-lg-6">
                <div class="hero-card p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-semibold">Smart Booking Preview</div>
                        <span class="badge text-bg-light border">UI</span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="p-3 border rounded-4">
                                <div class="fw-semibold">From</div>
                                <div class="text-muted2 small">Factory A</div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="p-3 border rounded-4">
                                <div class="fw-semibold">To</div>
                                <div class="text-muted2 small">Site B</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="p-3 border rounded-4">
                                <div class="fw-semibold mb-1">Available Vehicles</div>
                                <div class="text-muted2 small">Sedan • Van • Pickup</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="small text-muted2 mt-2">* ภาพจำลองสำหรับ Landing Page</div>
            </div>
        </div>
    </div>
</section>

<section id="features" class="section">
    <div class="container">
        <div class="section-title mb-4">
            <h2 class="fw-bold mb-2">Features</h2>
            <p class="text-muted2 mb-0">จองเร็ว อนุมัติชัด ตรวจสอบย้อนหลังได้</p>
        </div>
        <!-- ใส่ cards ต่อได้ -->
    </div>
</section>

<section id="contact" class="section bg-light">
    <div class="container">
        <div class="section-title mb-4">
            <h2 class="fw-bold mb-2">Contact</h2>
            <p class="text-muted2 mb-0">ทิ้งข้อมูลเพื่อขอ Demo หรือเริ่มใช้งาน</p>
        </div>
    </div>
</section>
