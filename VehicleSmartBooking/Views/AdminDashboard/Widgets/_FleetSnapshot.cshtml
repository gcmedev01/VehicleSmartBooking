@model VehicleSmartBooking.Features.Dashboard.Widgets.FleetSnapshotWidgetViewModel

<div class="row g-3">
    <div class="col-6 col-lg-4">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Active Vehicles</div>
            <div class="fs-4 fw-semibold">@Model.ActiveVehicles</div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Available</div>
            <div class="fs-4 fw-semibold">@Model.AvailableVehicles</div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Maintenance</div>
            <div class="fs-4 fw-semibold">@Model.MaintenanceVehicles</div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Out Of Service</div>
            <div class="fs-4 fw-semibold">@Model.OutOfServiceVehicles</div>
        </div>
    </div>
    <div class="col-6 col-lg-4">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Active Drivers</div>
            <div class="fs-4 fw-semibold">@Model.ActiveDrivers</div>
        </div>
    </div>
</div>
