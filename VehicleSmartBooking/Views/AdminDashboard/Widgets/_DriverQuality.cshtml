@model VehicleSmartBooking.Features.Dashboard.Widgets.DriverQualityWidgetViewModel

<div class="row g-3">
    <div class="col-12 col-lg-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">Average Score</div>
            <div class="fs-4 fw-semibold">@Model.AverageScore.ToString("0.0")</div>
            <div class="text-muted small">Ratings: @Model.RatingCount</div>
        </div>
    </div>
    <div class="col-12 col-lg-8">
        <div class="fw-semibold mb-2">Recent Ratings</div>
        @if (Model.RecentRatings.Count == 0)
        {
            <div class="text-muted">No ratings yet.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted">
                            <th>Driver</th>
                            <th class="text-end">Score</th>
                            <th class="text-end">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rating in Model.RecentRatings)
                        {
                            <tr>
                                <td>@rating.DriverName</td>
                                <td class="text-end">@rating.AverageScore.ToString("0.0")</td>
                                <td class="text-end">@rating.RatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
