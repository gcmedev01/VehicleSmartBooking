@model VehicleSmartBooking.Features.Dashboard.Widgets.CostVendorWidgetViewModel

<div class="row g-3">
    <div class="col-12 col-lg-4">
        <div class="border rounded p-3 h-100">
            <div class="text-muted small">External Cost</div>
            <div class="fs-4 fw-semibold">@Model.TotalExternalCost.ToString("N2")</div>
            <div class="text-muted small mt-2">Bookings: @Model.ExternalBookingCount</div>
        </div>
    </div>
    <div class="col-12 col-lg-8">
        <div class="fw-semibold mb-2">Top Vendors</div>
        @if (Model.TopVendors.Count == 0)
        {
            <div class="text-muted">No vendor data.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted">
                            <th>Vendor</th>
                            <th class="text-end">Cost</th>
                            <th class="text-end">Bookings</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vendor in Model.TopVendors)
                        {
                            <tr>
                                <td>@vendor.VendorName</td>
                                <td class="text-end">@vendor.TotalCost.ToString("N2")</td>
                                <td class="text-end">@vendor.BookingCount</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
