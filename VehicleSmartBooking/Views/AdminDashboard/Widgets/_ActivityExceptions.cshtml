@model VehicleSmartBooking.Features.Dashboard.Widgets.ActivityExceptionsWidgetViewModel

<div class="row g-3">
    <div class="col-6 col-lg-3">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Last 7 Days</div>
            <div class="fs-4 fw-semibold">@Model.RecentActivityCount</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="border rounded p-3 bg-light h-100">
            <div class="text-muted small">Exceptions</div>
            <div class="fs-4 fw-semibold">@Model.ExceptionCount</div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="fw-semibold mb-2">Recent Exceptions</div>
        @if (Model.RecentExceptions.Count == 0)
        {
            <div class="text-muted">No exceptions.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr class="text-muted">
                            <th>Booking</th>
                            <th>Requester</th>
                            <th>Status</th>
                            <th class="text-end">Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentExceptions)
                        {
                            <tr>
                                <td>#@item.BookingId</td>
                                <td>@item.RequesterName</td>
                                <td>@item.StatusLabel</td>
                                <td class="text-end">@item.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
