@model VehicleSmartBooking.Features.Dashboard.Widgets.KpiCardsWidgetViewModel

<div class="row g-3">
    <div class="col-6 col-lg-3">
        <div class="border rounded p-3 bg-light">
            <div class="text-muted small">Total Bookings</div>
            <div class="fs-4 fw-semibold">@Model.TotalBookings</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="border rounded p-3 bg-light">
            <div class="text-muted small">Active</div>
            <div class="fs-4 fw-semibold">@Model.ActiveBookings</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="border rounded p-3 bg-light">
            <div class="text-muted small">Completed</div>
            <div class="fs-4 fw-semibold">@Model.CompletedBookings</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="border rounded p-3 bg-light">
            <div class="text-muted small">Cancelled / Rejected</div>
            <div class="fs-4 fw-semibold">@Model.CancelledBookings</div>
        </div>
    </div>
</div>
