@model VehicleSmartBooking.Controllers.AccountController.ChangePasswordVm

@{
    Layout = "_VehicleBookingLayout";
    ViewData["Title"] = "Change Password";
    var requireCurrentPassword = ViewBag.RequireCurrentPassword as bool? ?? false;
}

<div class="vb-page-head vb-page-hero mb-4">
    <div class="vb-page-title">
        <div class="vb-page-icon">
            <img src="~/img/password.png" asp-append-version="true" class="vb-page-icon-img" />
        </div>
        <div>
            <h1 class="vb-page-h1">เปลี่ยนรหัสผ่าน</h1>
            <div class="vb-page-sub">ตั้งรหัสผ่านใหม่เพื่อความปลอดภัย</div>
        </div>
    </div>
</div>

<div class="vb-card p-3 p-md-4">
    <form asp-action="ChangePassword" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@(ViewData["ReturnUrl"] ?? "")" />

        <div class="text-danger small mb-3">
            @Html.ValidationSummary(excludePropertyErrors: true)
        </div>

        <div class="row g-3">
            @if (requireCurrentPassword)
            {
                <div class="col-12 col-md-6">
                    <label class="form-label">รหัสผ่านปัจจุบัน</label>
                    <input asp-for="CurrentPassword" type="password" class="form-control" autocomplete="current-password" />
                    <span class="text-danger small">@Html.ValidationMessageFor(m => m.CurrentPassword)</span>
                </div>

                <div class="col-12 col-md-6"></div>
            }

            <div class="col-12 col-md-6">
                <label class="form-label">รหัสผ่านใหม่</label>
                <input asp-for="NewPassword" type="password" class="form-control" autocomplete="new-password" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.NewPassword)</span>
                <div class="text-muted small mt-1">อย่างน้อย 8 ตัวอักษร</div>
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label">ยืนยันรหัสผ่านใหม่</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" autocomplete="new-password" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.ConfirmPassword)</span>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-controller="Home" asp-action="Index" class="btn btn-light">กลับ</a>
            <button type="submit" class="btn btn-ci">บันทึก</button>
        </div>
    </form>
</div>

<div class="modal fade" id="changePasswordErrorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">เปลี่ยนรหัสผ่านไม่สำเร็จ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                กรุณาตรวจสอบข้อมูลที่กรอกแล้วลองใหม่อีกครั้ง
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-ci" data-bs-dismiss="modal">ตกลง</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (!ViewData.ModelState.IsValid && Context.Request.Method == "POST")
    {
        <script>
            (() => {
                const modalEl = document.getElementById("changePasswordErrorModal");
                if (!modalEl) return;
                const modal = new bootstrap.Modal(modalEl);
                modal.show();
            })();
        </script>
    }
}
