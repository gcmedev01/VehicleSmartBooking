@using VehicleBooking.Web.Domain.Entities
@model IReadOnlyList<Notification>
@{
    ViewData["Title"] = "การแจ้งเตือน";
    Layout = "~/Views/Shared/_VehicleBookingLayout.cshtml";
}

<section class="vb-section is-active">
    <div class="vb-page-head mb-4">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
            <div>
                <h5 class="mb-0 fw-bold"><i class="bi bi-bell me-2"></i>การแจ้งเตือน</h5>
                <div class="text-muted small">แจ้งเตือนล่าสุด 50 รายการ</div>
            </div>
            @if (Model.Any(n => !n.IsRead))
            {
                <form asp-action="MarkAllRead" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-secondary">
                        <i class="bi bi-check2-all me-1"></i>ทำเครื่องหมายอ่านแล้วทั้งหมด
                    </button>
                </form>
            }
        </div>
    </div>

    @if (TempData["Success"] is string successMsg)
    {
        <div class="alert alert-success alert-dismissible mb-3" role="alert">
            @successMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="vb-card p-0 mb-3">
        <form asp-action="CreateTest" method="post" class="p-3 border-bottom bg-light d-flex align-items-center gap-2">
            @Html.AntiForgeryToken()
            <span class="text-muted small">ทดสอบระบบ:</span>
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-plus-circle me-1"></i>สร้างการแจ้งเตือนทดสอบ
            </button>
        </form>

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-bell-slash" style="font-size:2rem;"></i>
                <div class="mt-2">ไม่มีการแจ้งเตือน</div>
            </div>
        }
        else
        {
            <ul class="list-unstyled mb-0">
                @foreach (var n in Model)
                {
                    var rowBg = n.IsRead ? "" : "bg-light";
                    var titleWeight = n.IsRead ? "fw-normal" : "fw-semibold";
                    var localTime = n.CreatedAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
                    <li class="border-bottom @rowBg">
                        <a asp-action="MarkReadAndRedirect" asp-route-id="@n.NotificationId"
                           class="d-flex align-items-start gap-3 px-3 py-3 text-decoration-none text-dark">
                            <div class="pt-1 flex-shrink-0">
                                @if (!n.IsRead)
                                {
                                    <span class="badge rounded-pill bg-primary" style="width:8px;height:8px;padding:0;display:inline-block;"></span>
                                }
                                else
                                {
                                    <span style="width:8px;height:8px;display:inline-block;"></span>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <div class="small @titleWeight">@n.Title</div>
                                <div class="text-muted" style="font-size:.85rem;">@n.Message</div>
                                <div class="text-muted mt-1" style="font-size:.78rem;">
                                    <i class="bi bi-clock me-1"></i>@localTime
                                    @if (!n.IsRead)
                                    {
                                        <span class="ms-2 badge text-bg-primary" style="font-size:.7rem;">ใหม่</span>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(n.Url))
                            {
                                <div class="flex-shrink-0 text-muted pt-1">
                                    <i class="bi bi-chevron-right"></i>
                                </div>
                            }
                        </a>
                    </li>
                }
            </ul>
        }
    </div>
</section>
