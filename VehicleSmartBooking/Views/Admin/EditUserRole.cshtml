@model VehicleSmartBooking.Controllers.AdminController.EditUserRoleVm
@{
    Layout = "_VehicleBookingLayout";
    ViewData["Title"] = "Edit User Role";
    ViewData["ActiveNav"] = "AdminUsers";

    var displayName = Model.UsernameTH ?? Model.UsernameEN ?? Model.UserCode;
}

<div class="vb-page-head vb-page-hero mb-4">
    <div class="vb-page-title">
        <div class="vb-page-icon">
            <img src="~/img/man.png" asp-append-version="true" class="vb-page-icon-img" />
        </div>
        <div>
            <h1 class="vb-page-h1">Edit User Role</h1>
            <div class="vb-page-sub">@displayName (@Model.UserCode)</div>
        </div>
    </div>
</div>

<div class="vb-card p-3">
    <form asp-action="EditUserRole" asp-route-id="@Model.UserId" method="post" class="d-flex flex-column gap-3">
        @Html.AntiForgeryToken()
        <div class="text-danger" asp-validation-summary="ModelOnly"></div>

        @if (Model.IsDriver)
        {
            <div class="alert alert-warning mb-0">Driver role cannot be edited.</div>
        }

        <div>
            <label class="form-label fw-semibold">Roles</label>
            <div class="d-flex flex-wrap gap-2">
                <input class="btn-check" type="checkbox" id="roleUser" name="RoleUser" value="true" @(Model.RoleUser ? "checked" : "") @(Model.IsDriver ? "disabled" : "") />
                <label class="btn btn-outline-secondary rounded-pill" for="roleUser">User</label>

                <input class="btn-check" type="checkbox" id="roleAdmin" name="RoleAdmin" value="true" @(Model.RoleAdmin ? "checked" : "") @(Model.IsDriver ? "disabled" : "") />
                <label class="btn btn-outline-secondary rounded-pill" for="roleAdmin">Admin</label>

                <input class="btn-check" type="checkbox" id="roleApprover" name="RoleApprover" value="true" @(Model.RoleApprover ? "checked" : "") @(Model.IsDriver ? "disabled" : "") />
                <label class="btn btn-outline-secondary rounded-pill" for="roleApprover">Approver</label>
            </div>
            <div class="text-muted small mt-2">User, Admin, and Approver can be combined.</div>
        </div>

        <div class="d-flex justify-content-end gap-2">
            <a asp-action="Users" class="btn btn-light">Back</a>
            @if (Model.HasCredential)
            {
                <button type="submit" class="btn btn-warning" form="resetUserForm">Reset Password</button>
            }
            <button type="submit" class="btn btn-ci" @(Model.IsDriver ? "disabled" : "")>Save</button>
        </div>
    </form>

    @if (Model.HasCredential)
    {
        <form id="resetUserForm" asp-action="ResetUserPassword" asp-route-id="@Model.UserId" method="post">
            @Html.AntiForgeryToken()
        </form>
    }
</div>
