@model VehicleSmartBooking.Controllers.AdminController.CreateDriverVm
@{
    Layout = "_VehicleBookingLayout";
    ViewData["Title"] = "Edit Driver";
}

<div class="vb-page-head vb-page-hero mb-4">
    <div class="vb-page-title">
        <div class="vb-page-icon">??</div>
        <div>
            <h1 class="vb-page-h1">Edit Driver</h1>
        </div>
    </div>
</div>

<div class="vb-card p-3">
    <form method="post" asp-action="UpdateDriver" asp-route-id="@ViewBag.DriverId">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Driver Code</label>
                <input asp-for="DriverCode" class="form-control" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label">Name (TH)</label>
                <input asp-for="DriverNameTH" class="form-control" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Name (EN)</label>
                <input asp-for="DriverNameEN" class="form-control" />
            </div>

            <div class="col-md-4">
                <label class="form-label">‡∫Õ√Ï‚∑√»—æ∑Ï</label>
                <input asp-for="Phone" class="form-control" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.Phone)</span>
            </div>

            <div class="col-md-6">
                <label class="form-label">Vehicle</label>
                <select asp-for="VehicleId" asp-items="(IEnumerable<SelectListItem>)ViewBag.Vehicles" class="form-select">
                    <option value="">-- Select vehicle --</option>
                </select>
            </div>

            <div class="col-md-6">
                <div class="form-check mt-3">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label class="form-check-label">Is Active</label>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-4 gap-2">
            <a asp-action="Drivers" class="btn btn-light">Cancel</a>
            <button class="btn btn-warning" type="submit" form="resetDriverForm">Reset Password</button>
            <button class="btn btn-primary">Save</button>
        </div>
    </form>

    <form id="resetDriverForm" method="post" asp-action="ResetDriverPassword" asp-route-id="@ViewBag.DriverId">
        @Html.AntiForgeryToken()
    </form>
</div>