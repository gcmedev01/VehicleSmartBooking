@using System.ComponentModel.DataAnnotations
@model VehicleSmartBooking.Controllers.AdminController.CreateApproverVm

@{
    Layout = "_VehicleBookingLayout";
    ViewData["Title"] = "Create Approver";
    ViewData["ActiveNav"] = "AdminUsers";
}

<div class="vb-page-head vb-page-hero mb-4">
    <div class="vb-page-title">
        <div class="vb-page-icon">🛡️</div>
        <div>
            <h1 class="vb-page-h1">Create Approver</h1>
            <div class="vb-page-sub">เพิ่มผู้อนุมัติ (สร้างบัญชี local) และกำหนดรหัสผ่านเริ่มต้น</div>
        </div>
    </div>
</div>

<div class="vb-card p-3 p-md-4">
    <form asp-controller="Admin" asp-action="CreateApprover" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="text-danger small mb-3">
            @Html.ValidationSummary(excludePropertyErrors: true)
        </div>

        <div class="row g-3">
            <div class="col-12 col-md-4">
                <label class="form-label">Approver Code</label>
                <input asp-for="ApproverCode" class="form-control" placeholder="เช่น APRV001" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.ApproverCode)</span>
                <div class="text-muted small mt-1">ใช้เป็น Username สำหรับ login</div>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">ชื่อ-สกุล (TH)</label>
                <input asp-for="ApproverNameTH" class="form-control" placeholder="เช่น นาย สมชาย เหมาะสม" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.ApproverNameTH)</span>
            </div>

            <div class="col-12 col-md-4">
                <label class="form-label">Name (EN)</label>
                <input asp-for="ApproverNameEN" class="form-control" placeholder="เช่น Somchai Homsom" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.ApproverNameEN)</span>
            </div>

            <div class="col-12 col-md-6">
                <label class="form-label">Initial Password</label>
                <input asp-for="InitialPassword" class="form-control" placeholder="เช่น Welcome@123" />
                <span class="text-danger small">@Html.ValidationMessageFor(m => m.InitialPassword)</span>
                <div class="text-muted small mt-1">ถ้าไม่กรอก ระบบจะใช้ค่าเริ่มต้น (Welcome@123)</div>
            </div>

            <div class="col-12 col-md-6">
                <div class="form-check mt-1">
                    <input class="form-check-input" type="checkbox" id="IsActive" name="IsActive" value="true" @(Model?.IsActive == true ? "checked" : "") />
                    <input type="hidden" name="IsActive" value="false" />
                    <label class="form-check-label" for="IsActive">Active</label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <a asp-controller="Admin" asp-action="Users" class="btn btn-light">Cancel</a>
            <button type="submit" class="btn btn-primary">Save Approver</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
