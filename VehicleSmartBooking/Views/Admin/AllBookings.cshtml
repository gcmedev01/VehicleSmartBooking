@using System.Collections.Generic
@using VehicleBooking.Web.Domain.Enums
@model IList<VehicleSmartBooking.Controllers.AdminController.AllBookingsRowVm>

@{
    Layout = "_VehicleBookingLayout";
    ViewData["Title"] = "All Task";
    ViewData["ActiveNav"] = "AllTasks";
    var functionOptions = ViewBag.FunctionOptions as IEnumerable<string> ?? Enumerable.Empty<string>();
    var deptOptions = ViewBag.DeptOptions as IEnumerable<string> ?? Enumerable.Empty<string>();
    var divOptions = ViewBag.DivOptions as IEnumerable<string> ?? Enumerable.Empty<string>();

    // ---------- current filter values (server-side; sticky across submit/pagination) ----------
    var selectedSearch = ViewBag.Search as string ?? "";
    var selectedStatus = ViewBag.Status as BookingStatus?;
    var selectedTripType = ViewBag.TripType as TripType?;
    var selectedServiceType = ViewBag.ServiceType as string ?? "";

    // Curated status filter order (mirrors the workflow, same list previously used client-side).
    var statusOptions = new[]
    {
        BookingStatus.Submitted,
        BookingStatus.WaitingApproval,
        BookingStatus.WaitingDriverAccept,
        BookingStatus.DriverAccepted,
        BookingStatus.ApprovedSelfDrive,
        BookingStatus.WaitingAdminVendorQuotation,
        BookingStatus.WaitingUserVendorAccept,
        BookingStatus.WaitingAdminVendorConfirm,
        BookingStatus.VendorRejectedByUser,
        BookingStatus.WaitingAdminPersonal,
        BookingStatus.Completed,
        BookingStatus.Rated,
        BookingStatus.Rejected,
        BookingStatus.Cancelled,
        BookingStatus.AdminActionRequired
    };

    // ---------- UI helpers ----------
    string StatusClass(BookingStatus st) => VehicleBooking.Web.Domain.Helpers.BookingStatusHelper.StatusCssClass(st);

    string StatusText(BookingStatus st) => st switch
    {
        BookingStatus.Draft => "ร่าง",
        BookingStatus.Submitted => "ส่งคำขอแล้ว",
        BookingStatus.WaitingApproval => "รออนุมัติ",
        BookingStatus.WaitingDriverAccept => "รอพนักงานขับรถตอบรับ",
        BookingStatus.DriverAccepted => "พนักงานขับรถตอบรับ",
        BookingStatus.ApprovedSelfDrive => "อนุมัติแล้ว",
        BookingStatus.WaitingAdminVendorQuotation => "รอเสนอราคาผู้ให้บริการ",
        BookingStatus.WaitingUserVendorAccept => "รอผู้ขอใช้ยอมรับผู้ให้บริการ",
        BookingStatus.WaitingAdminVendorConfirm => "รอยืนยันผู้ให้บริการ",
        BookingStatus.VendorRejectedByUser => "ผู้ขอใช้ปฏิเสธผู้ให้บริการ",
        BookingStatus.WaitingAdminPersonal => "รอผู้ดูแลอนุมัติรถส่วนตัว",
        BookingStatus.Completed => "เสร็จสิ้น",
        BookingStatus.Rated => "ให้คะแนนแล้ว",
        BookingStatus.Rejected => "ถูกปฏิเสธ",
        BookingStatus.Cancelled => "ยกเลิก",
        BookingStatus.AdminActionRequired => "รอผู้ดูแลดำเนินการ",
        _ => st.ToString()
    };

    string TripChipText(TripType t) => t switch
    {
        TripType.InProvince => "ในจังหวัดระยอง",
        TripType.OutProvince => "นอกจังหวัด",
        _ => t.ToString()
    };

    string TripChipClass(TripType t) => t == TripType.OutProvince ? "vb-chip vb-chip-alt" : "vb-chip";

    string VehicleText(VehicleType v) => v switch
    {
        VehicleType.Pickup => "รถกระบะ",
        VehicleType.Van => "รถตู้",
        VehicleType.Sedan => "รถเก๋ง",
        VehicleType.Electric => "รถไฟฟ้า",
        _ => v.ToString()
    };

    // Route values shared by every pagination link so search/filters are never lost when the
    // user navigates between pages. Only "page" changes per link.
    Dictionary<string, string> PageRouteValues(int targetPage) => new()
    {
        ["search"] = selectedSearch,
        ["status"] = selectedStatus?.ToString() ?? "",
        ["tripType"] = selectedTripType?.ToString() ?? "",
        ["serviceType"] = selectedServiceType,
        ["startDate"] = ViewBag.StartDate as string ?? "",
        ["endDate"] = ViewBag.EndDate as string ?? "",
        ["functionAbbr"] = ViewBag.FunctionAbbr as string ?? "",
        ["deptAbbr"] = ViewBag.DeptAbbr as string ?? "",
        ["divAbbr"] = ViewBag.DivAbbr as string ?? "",
        ["page"] = targetPage.ToString()
    };
}

<div class="vb-page-head vb-page-hero mb-4">
    <div class="vb-page-title">
        <div class="vb-page-icon">
            <img src="~/img/skills.png" asp-append-version="true" class="vb-page-icon-img" />
        </div>
        <div>
            <h1 class="vb-page-h1">All Task</h1>
            <div class="vb-page-sub">คำร้องขอทั้งหมด</div>
        </div>
    </div>

    <div class="vb-page-meta d-none d-md-flex">
        <span class="vb-meta-pill">History</span>
    </div>
</div>

<!-- Filters + Stats (server-side search/filter/pagination) -->
<div class="vb-card p-3 p-md-4 mb-3">
    <form method="get" asp-action="AllBookings" class="row g-3 align-items-end mb-0">
        <div class="col-12">
            <label class="form-label">ค้นหา</label>
            <input type="text" class="form-control" name="search" value="@selectedSearch"
                   placeholder="ค้นหาเลขที่ใบจอง ชื่อผู้ขอ เส้นทาง หรือทะเบียนรถ" />
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label">สถานะ</label>
            <select class="form-select" name="status">
                <option value="" selected="@(selectedStatus is null ? "selected" : null)">ทั้งหมด</option>
                @foreach (var s in statusOptions)
                {
                    <option value="@s" selected="@(selectedStatus == s ? "selected" : null)">@StatusText(s)</option>
                }
            </select>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label">ประเภทการเดินทาง</label>
            <select class="form-select" name="tripType">
                <option value="" selected="@(selectedTripType is null ? "selected" : null)">ทั้งหมด</option>
                <option value="@TripType.InProvince" selected="@(selectedTripType == TripType.InProvince ? "selected" : null)">ในจังหวัดระยอง</option>
                <option value="@TripType.OutProvince" selected="@(selectedTripType == TripType.OutProvince ? "selected" : null)">นอกจังหวัด</option>
            </select>
        </div>

        <div class="col-12 col-md-4">
            <label class="form-label">ประเภทบริการ</label>
            <select class="form-select" name="serviceType">
                <option value="" selected="@(string.IsNullOrEmpty(selectedServiceType) ? "selected" : null)">ทั้งหมด</option>
                <option value="company" selected="@(selectedServiceType == "company" ? "selected" : null)">รถในบริษัท</option>
                <option value="external" selected="@(selectedServiceType == "external" ? "selected" : null)">รถภายนอกบริษัท</option>
                <option value="personal" selected="@(selectedServiceType == "personal" ? "selected" : null)">รถส่วนตัว</option>
            </select>
        </div>

        <div class="col-6 col-md-3">
            <label class="form-label">วันที่เริ่มต้น</label>
            <input type="date" class="form-control" name="startDate" value="@ViewBag.StartDate" />
        </div>

        <div class="col-6 col-md-3">
            <label class="form-label">วันที่สิ้นสุด</label>
            <input type="date" class="form-control" name="endDate" value="@ViewBag.EndDate" />
        </div>

        <div class="col-4 col-md-2">
            <label class="form-label">Function Abbr</label>
            <select class="form-select" name="functionAbbr">
                <option value="">ทั้งหมด</option>
                @foreach (var item in functionOptions)
                {
                    <option value="@item" selected="@(string.Equals(ViewBag.FunctionAbbr as string, item, StringComparison.Ordinal) ? "selected" : null)">@item</option>
                }
            </select>
        </div>

        <div class="col-4 col-md-2">
            <label class="form-label">Dept Abbr</label>
            <select class="form-select" name="deptAbbr">
                <option value="">ทั้งหมด</option>
                @foreach (var item in deptOptions)
                {
                    <option value="@item" selected="@(string.Equals(ViewBag.DeptAbbr as string, item, StringComparison.Ordinal) ? "selected" : null)">@item</option>
                }
            </select>
        </div>

        <div class="col-4 col-md-2">
            <label class="form-label">Div Abbr</label>
            <select class="form-select" name="divAbbr">
                <option value="">ทั้งหมด</option>
                @foreach (var item in divOptions)
                {
                    <option value="@item" selected="@(string.Equals(ViewBag.DivAbbr as string, item, StringComparison.Ordinal) ? "selected" : null)">@item</option>
                }
            </select>
        </div>

        <div class="col-12 d-grid d-flex gap-2 justify-content-center">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> ค้นหารายงาน
            </button>
            <button type="submit"
                    formaction="@Url.Action("ExportBookingsExcel", "Admin")"
                    formmethod="get"
                    class="btn btn-success">
                Export Excel
            </button>
            <a asp-action="AllBookings" asp-route-startDate="" class="btn btn-light">ล้างตัวกรอง</a>
        </div>
    </form>
</div>

<!-- Desktop table -->
<div class="vb-card p-0 d-none d-md-block">
    <div class="vb-table-head px-3 px-md-4 py-3">
        <div class="fw-semibold">รายการคำขอ</div>
    </div>

    <div class="table-responsive">
        <table class="table vb-table mb-0">
            <thead>
                <tr>
                    <th style="width:130px;">Booking #</th>
                    <th style="width:140px;">ประเภท</th>
                    <th style="width:150px;">ประเภทรถ</th>
                    <th style="width:170px;">ประเภทบริการ</th>
                    <th style="min-width:240px;">เส้นทาง</th>
                    <th style="width:210px;">ช่วงเวลา</th>
                    <th style="width:190px;">สถานะ</th>
                    <th style="width:100px;" class="text-end">การทำงาน</th>
                </tr>
            </thead>

            <tbody>
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">ไม่พบรายการที่ตรงกับตัวกรอง</td>
                    </tr>
                }
                else
                {
                    foreach (var b in Model)
                    {
                        <tr data-booking-id="@b.BookingId">
                            <td class="fw-semibold">VS-@b.BookingId</td>

                            <td>
                                <span class="@TripChipClass(b.TripType)">@TripChipText(b.TripType)</span>
                                <div class="text-muted small mt-1">@(!string.IsNullOrWhiteSpace(b.JobNo) ? b.JobNo : "-")</div>
                            </td>

                            <td>
                                <span class="vb-veh-pill">@VehicleText(b.VehicleTypeRequested)</span>
                                @if (!string.IsNullOrWhiteSpace(b.PlateNo))
                                {
                                    <div class="text-muted small mt-1">@b.PlateNo</div>
                                }
                            </td>

                            <td>
                                <div class="fw-semibold">@b.ServiceTypeText</div>
                                @if (!string.IsNullOrWhiteSpace(b.VendorName))
                                {
                                    <div class="small text-muted">@b.VendorName</div>
                                }
                            </td>

                            <td>
                                <div><span class="fw-semibold">จุดเริ่มต้น:</span> @b.PickupDisplay</div>
                                <div><span class="fw-semibold">จุดสิ้นสุด:</span> @b.DestinationDisplay</div>
                            </td>

                            <td>
                                <div><span class="fw-semibold">เริ่ม:</span> @b.StartDisplay</div>
                                <div><span class="fw-semibold">สิ้นสุด:</span> @b.EndDisplay</div>
                            </td>

                            <td>
                                <span class="vb-status @StatusClass(b.Status)">@StatusText(b.Status)</span>
                                <div class="text-muted small mt-1">@(b.RequesterName ?? "-")</div>
                            </td>

                            <td class="text-end">
                                <a asp-action="Detail" asp-route-id="@b.BookingId"
                                   class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Mobile cards -->
<div class="d-md-none">
    @if (Model == null || !Model.Any())
    {
        <div class="vb-card p-3 text-center text-muted">ไม่พบรายการที่ตรงกับตัวกรอง</div>
    }
    else
    {
        foreach (var b in Model)
        {
            <div class="vb-history-card vb-card p-3 mb-3" data-booking-id="@b.BookingId">
                <div class="d-flex justify-content-between align-items-start gap-2">
                    <div class="fw-semibold">VS-@b.BookingId</div>
                    <span class="vb-status @StatusClass(b.Status)">@StatusText(b.Status)</span>
                </div>

                <div class="mt-2">
                    <span class="vb-veh-pill">@VehicleText(b.VehicleTypeRequested)</span>
                    @if (!string.IsNullOrWhiteSpace(b.PlateNo))
                    {
                        <span class="text-muted small ms-1">@b.PlateNo</span>
                    }
                </div>

                <div class="mt-1">
                    <span class="fw-semibold small">@b.ServiceTypeText</span>
                    @if (!string.IsNullOrWhiteSpace(b.ServiceTypePlateNo))
                    {
                        <span class="text-muted small ms-1">(ทะเบียน: @b.ServiceTypePlateNo)</span>
                    }
                </div>

                <div class="mt-2 small">
                    <div><span class="fw-semibold">จุดเริ่มต้น:</span> @b.PickupDisplay</div>
                    <div><span class="fw-semibold">จุดสิ้นสุด:</span> @b.DestinationDisplay</div>
                </div>

                <div class="mt-2 small text-muted">
                    <div><span class="fw-semibold">เริ่ม:</span> @b.StartDisplay</div>
                    <div><span class="fw-semibold">สิ้นสุด:</span> @b.EndDisplay</div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-3">
                    <span class="@TripChipClass(b.TripType)">@TripChipText(b.TripType)</span>
                    <a asp-action="Detail" asp-route-id="@b.BookingId"
                       class="btn btn-sm btn-outline-secondary">
                        ดู
                    </a>
                </div>
            </div>
        }
    }
</div>

@{
    var pageNo = ViewBag.Page is int p ? p : 1;
    var totalPages = ViewBag.TotalPages is int tp ? tp : 0;
    var totalCount = ViewBag.TotalCount is int tc ? tc : 0;
}

@if (totalPages > 1)
{
    <nav class="mt-3" aria-label="Bookings pagination">
        <div class="text-muted small mb-2 text-center text-md-start">
            หน้า @pageNo จาก @totalPages (ทั้งหมด @totalCount รายการ)
        </div>
        <ul class="pagination pagination-sm justify-content-center justify-content-md-start flex-wrap mb-0">
            <li class="page-item @(pageNo <= 1 ? "disabled" : "")">
                <a class="page-link" asp-action="AllBookings" asp-all-route-data="@PageRouteValues(pageNo - 1)">ก่อนหน้า</a>
            </li>

            @{
                var startPage = Math.Max(1, pageNo - 2);
                var endPage = Math.Min(totalPages, pageNo + 2);
            }
            @if (startPage > 1)
            {
                <li class="page-item"><a class="page-link" asp-action="AllBookings" asp-all-route-data="@PageRouteValues(1)">1</a></li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @for (var i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == pageNo ? "active" : "")">
                    <a class="page-link" asp-action="AllBookings" asp-all-route-data="@PageRouteValues(i)">@i</a>
                </li>
            }

            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
                <li class="page-item"><a class="page-link" asp-action="AllBookings" asp-all-route-data="@PageRouteValues(totalPages)">@totalPages</a></li>
            }

            <li class="page-item @(pageNo >= totalPages ? "disabled" : "")">
                <a class="page-link" asp-action="AllBookings" asp-all-route-data="@PageRouteValues(pageNo + 1)">ถัดไป</a>
            </li>
        </ul>
    </nav>
}
