<div class="vb-page-head vb-page-hero mb-4">
    <div class="vb-page-title">
        <div class="vb-page-icon">??</div>
        <div>
            <h1 class="vb-page-h1">Booking #@Model.BookingId</h1>
            <div class="vb-page-sub">Admin actions</div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-md-6">
        <div class="vb-card p-3">
            <div class="fw-semibold mb-2">Basic</div>
            <div>Requester: @(Model.Requester?.UsernameTH ?? Model.Requester?.UsernameEN ?? Model.RequesterUserId.ToString())</div>
            <div>Start: @Model.StartAtUtc.ToLocalTime().ToString("g")</div>
            <div>Status: @Model.Status</div>
        </div>

        @* Vendor quote section *@
        <div class="vb-card p-3 mt-3">
            <div class="fw-semibold mb-2">Vendor Quote</div>

            @if (Model.ExternalRental == null)
            {
                <div class="text-muted">No vendor quote yet.</div>
            }
            else
            {
                <div><strong>Vendor:</strong> @Model.ExternalRental.VendorName</div>
                <div><strong>Price:</strong> @(Model.ExternalRental.QuotedPrice?.ToString("C") ?? "-")</div>
                <div><strong>Sent:</strong> @(Model.ExternalRental.QuoteSentAtUtc?.ToLocalTime().ToString("g") ?? "-")</div>
                <div><strong>User decision:</strong> @Model.ExternalRental.UserDecision</div>
                @if (!string.IsNullOrWhiteSpace(Model.ExternalRental.Note))
                {
                    <div><strong>Note:</strong> @Model.ExternalRental.Note</div>
                }
            }

            @* Show send/resend quote form when booking awaiting admin quotation or admin wants to resend while user hasn't decided *@
            @if (Model.Status == VehicleBooking.Web.Domain.Enums.BookingStatus.WaitingAdminVendorQuotation || Model.Status == VehicleBooking.Web.Domain.Enums.BookingStatus.WaitingUserVendorAccept)
            {
                <hr />
                <form asp-action="SendVendorQuote" asp-route-id="@Model.BookingId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">Vendor name</label>
                        <input name="VendorName" class="form-control" value="@(Model.ExternalRental?.VendorName ?? "")" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Quoted price</label>
                        <input name="QuotedPrice" type="number" step="0.01" class="form-control" value="@(Model.ExternalRental?.QuotedPrice?.ToString() ?? "")" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Note</label>
                        <textarea name="Note" class="form-control">@(Model.ExternalRental?.Note ?? "")</textarea>
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-action="Worklist" class="btn btn-light">Back</a>
                        <button class="btn btn-primary" type="submit">Send / Update Quote</button>
                    </div>
                </form>
            }
        </div>

        @* Confirm rental details (after approvals complete) *@
        @if (Model.Status == VehicleBooking.Web.Domain.Enums.BookingStatus.WaitingAdminVendorConfirm)
        {
            <div class="vb-card p-3 mt-3">
                <div class="fw-semibold mb-2">Confirm Rental Details</div>
                <form asp-action="ConfirmVendor" asp-route-id="@Model.BookingId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-2">
                        <label class="form-label">·ŠąŗÕĀ¹Ć¶</label>
                        <input name="RentalPlateNo" class="form-control" value="@(Model.ExternalRental?.RentalPlateNo ?? "")" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">ĆŅĀŖ×čĶ¾¹Ń”§Ņ¹¢ŃŗĆ¶</label>
                        <input name="RentalDriverName" class="form-control" value="@(Model.ExternalRental?.RentalDriverName ?? "")" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">ąŗĶĆģā·Ć¾¹Ń”§Ņ¹¢ŃŗĆ¶</label>
                        <input name="RentalDriverPhone" class="form-control" value="@(Model.ExternalRental?.RentalDriverPhone ?? "")" />
                    </div>
                    <div class="d-flex gap-2 justify-content-end">
                        <button class="btn btn-success" type="submit">Confirm</button>
                    </div>
                </form>
            </div>
        }

        <div class="vb-card p-3 mt-3">
            <div class="fw-semibold mb-2">Admin Controls</div>
            <form asp-action="ForceComplete" asp-route-id="@Model.BookingId" method="post" class="mb-2">
                @Html.AntiForgeryToken()
                <input type="hidden" name="comment" value="Admin force complete" />
                <button class="btn btn-outline-danger">Force Complete</button>
            </form>
        </div>
    </div>

    <div class="col-12 col-md-6">
        <div class="vb-card p-3">
            <div class="fw-semibold mb-2">Attachments</div>
            @if (Model.Attachments?.Any() == true)
            {
                <ul class="list-unstyled mb-0">
                    @foreach (var a in Model.Attachments)
                    {
                        <li class="mb-1"><a href="@a.StoragePath" target="_blank">@a.FileName</a></li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">No attachments</div>
            }
        </div>

        <div class="vb-card p-3 mt-3">
            <div class="fw-semibold mb-2">Approvals</div>
            @if (Model.Approvals?.Any() == true)
            {
                <ul class="list-unstyled">
                    @foreach (var a in Model.Approvals.OrderBy(x => x.LevelNo))
                    {
                        <li>@a.LevelNo - @a.ApproverUserId - @a.Status (@(a.ActionAtUtc?.ToLocalTime().ToString("g") ?? "-"))</li>
                    }
                </ul>
            }
            else
            {
                <div class="text-muted">No approval rows</div>
            }
        </div>
    </div>
</div>