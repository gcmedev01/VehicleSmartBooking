@model VehicleBooking.Web.Domain.Entities.Booking
@using VehicleBooking.Web.Domain.Enums
@using System.Globalization
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    string PhotoGroupLabel(DriverCompletionPhotoGroup g) => g switch
    {
        DriverCompletionPhotoGroup.OdometerBeforeAfter => "รูปเลขกิโลเมตรก่อนเริ่ม/หลังให้บริการ",
        DriverCompletionPhotoGroup.ExteriorCondition   => "รูปสภาพรถและภายนอกรถ",
        DriverCompletionPhotoGroup.InteriorCondition   => "รูปภาพตรวจสอบสภาพรถภายใน",
        _ => g.ToString()
    };
}

@{
    Layout = "_VehicleBookingLayout";
    ViewData["Title"] = $"Booking #{Model?.BookingId}";

    if (Model == null)
    {
        return;
    }

    string TripText(TripType t) => t switch
    {
        TripType.InProvince => "ในจังหวัด",
        TripType.OutProvince => "นอกจังหวัด",
        _ => t.ToString()
    };

    string VehicleText(VehicleType v) => v switch
    {
        VehicleType.Pickup => "รถกระบะ",
        VehicleType.Van => "รถตู้",
        VehicleType.Sedan => "รถเก๋ง",
        VehicleType.Electric => "รถไฟฟ้า",
        _ => v.ToString()
    };

    string SpecialOccasionText(SpecialOccasionType t) => t switch
    {
        SpecialOccasionType.Wedding => "งานแต่ง",
        SpecialOccasionType.Ordination => "งานบวช",
        _ => t.ToString()
    };

    string StatusClass(BookingStatus st) => VehicleBooking.Web.Domain.Helpers.BookingStatusHelper.StatusCssClass(st);

    string StatusText(BookingStatus st) => st switch
    {
        BookingStatus.Draft => "ร่าง",
        BookingStatus.Submitted => "ส่งคำขอแล้ว",
        BookingStatus.WaitingApproval => "รออนุมัติ",
        BookingStatus.WaitingDriverAccept => "รอพนักงานขับรถตอบรับ",
        BookingStatus.DriverAccepted => "พนักงานขับรถตอบรับ",
        BookingStatus.ApprovedSelfDrive => "อนุมัติแล้ว",
        BookingStatus.WaitingAdminVendorQuotation => "รอเสนอราคาผู้ให้บริการ",
        BookingStatus.WaitingUserVendorAccept => "รอผู้ขอใช้ยอมรับผู้ให้บริการ",
        BookingStatus.WaitingAdminVendorConfirm => "รอยืนยันผู้ให้บริการ",
        BookingStatus.VendorRejectedByUser => "ผู้ขอใช้ปฏิเสธผู้ให้บริการ",
        BookingStatus.WaitingAdminPersonal => "รอผู้ดูแลอนุมัติรถส่วนตัว",
        BookingStatus.Completed => "เสร็จสิ้น",
        BookingStatus.Rated => "ให้คะแนนแล้ว",
        BookingStatus.Rejected => "ถูกปฏิเสธ",
        BookingStatus.Cancelled => "ยกเลิก",
        BookingStatus.AdminActionRequired => "รอผู้ดูแลดำเนินการ",
        _ => st.ToString()
    };

    string ApprovalStatusText(ApprovalStatus st) => st switch
    {
        ApprovalStatus.Pending => "รอดำเนินการ",
        ApprovalStatus.Approved => "อนุมัติ",
        ApprovalStatus.Rejected => "ไม่อนุมัติ",
        _ => st.ToString()
    };

    string ApprovalBadgeClass(ApprovalStatus st) => st switch
    {
        ApprovalStatus.Pending => "bg-warning text-dark",
        ApprovalStatus.Approved => "bg-success",
        ApprovalStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };

    // ===== Derived values (กัน Razor เพี้ยน) =====

    string vehicleText;
    string driverText;
    string driverPhone;

    if (Model.IsExternalRental)
    {
        vehicleText = string.IsNullOrWhiteSpace(Model.ExternalRental?.RentalPlateNo)
        ? "-"
        : Model.ExternalRental.RentalPlateNo;

        driverText = string.IsNullOrWhiteSpace(Model.ExternalRental?.RentalDriverName)
        ? "-"
        : Model.ExternalRental.RentalDriverName;

        driverPhone = string.IsNullOrWhiteSpace(Model.ExternalRental?.RentalDriverPhone)
        ? "-"
        : Model.ExternalRental.RentalDriverPhone;
    }
    else
    {
        vehicleText = Model.AssignedVehicle != null
        ? Model.AssignedVehicle.PlateNo
        : Model.AssignedVehicleId.HasValue
        ? $"#{Model.AssignedVehicleId}"
        : "-";

        driverText = Model.AssignedDriver != null
        ? Model.AssignedDriver.User?.UsernameTH
        ?? Model.AssignedDriver.User?.UsernameEN
        ?? $"#{Model.AssignedDriver.DriverId}"
        : Model.AssignedDriverId.HasValue
        ? $"#{Model.AssignedDriverId}"
        : "ไม่มีพนักงานขับรถ";

        driverPhone = string.IsNullOrWhiteSpace(Model.AssignedDriver?.Phone)
        ? "-"
        : Model.AssignedDriver.Phone;
    }

    var requesterName =
        !string.IsNullOrWhiteSpace(Model.Requester?.UsernameTH)
            ? Model.Requester.UsernameTH
            : !string.IsNullOrWhiteSpace(Model.Requester?.UsernameEN)
                ? Model.Requester.UsernameEN
                : Model.RequesterUserId.ToString();

    var requesterCode = Model.Requester?.UserCode ?? "-";
    var passengers = Model.PassengerCount ?? 1;
    var jobNo = string.IsNullOrWhiteSpace(Model.JobNo) ? "-" : Model.JobNo;
    var costCenter = string.IsNullOrWhiteSpace(Model.CostCenter) ? "-" : Model.CostCenter;
    var soNo = string.IsNullOrWhiteSpace(Model.SONo) ? "-" : Model.SONo;

    // External rental info
    var external = Model.ExternalRental;

    var serviceTypeText = Model.IsPersonal
        ? "รถส่วนตัว"
        : Model.IsExternalRental
            ? "ผู้ให้บริการภายนอก"
            : "รถบริษัท";
    var tripTypeText = TripText(Model.TripType);
    var vehicleTypeText = VehicleText(Model.VehicleTypeRequested);
    var statusText = StatusText(Model.Status);
    var specialOccasionText = Model.SpecialOccasionType.HasValue ? SpecialOccasionText(Model.SpecialOccasionType.Value) : null;

    var createdLocal = Model.CreatedAtUtc.ToLocalTime();
}

<section id="sec-history" class="vb-section is-active">
    <!-- ===== Page Head ===== -->
    <div class="vb-page-head vb-page-hero mb-4">
        <div class="vb-page-title">
            <div class="vb-page-icon">
                <img src="~/img/task.png" asp-append-version="true" class="vb-page-icon-img" />
            </div>
            <div>
                <h1 class="vb-page-h1">Booking Detail</h1>
                <div class="vb-page-sub">ข้อมูลการจอง #@Model.BookingId</div>
            </div>
        </div>

        <div class="vb-page-meta d-none d-md-flex">
            <span class="vb-meta-pill">Task</span>
            <span class="vb-meta-pill">Booking #@Model.BookingId</span>
        </div>
    </div>

    @if (TempData["Success"] is string adminSuccessMsg && !string.IsNullOrWhiteSpace(adminSuccessMsg))
    {
        <div class="alert alert-success alert-dismissible mb-3" role="alert">
            @adminSuccessMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] is string adminErrorMsg && !string.IsNullOrWhiteSpace(adminErrorMsg))
    {
        <div class="alert alert-danger alert-dismissible mb-3" role="alert">
            @adminErrorMsg
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-3">
        <div class="col-12 col-md-6">
            <!-- Request Info -->
            <div class="vb-card p-3 p-md-4 mb-3">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="h5 mt-2">รายละเอียดใบงาน</div>
                    </div>
                    <div class="d-flex align-content-center justify-content-end">
                        <span class="vb-status @StatusClass(Model.Status)">@StatusText(Model.Status)</span>
                    </div>
                </div>

                <div class="vb-divider my-3"></div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">เลขที่ใบงาน</div>
                    <div class="col-12 col-md-8 text-muted">VS-@Model.BookingId</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">เลขที่งานอ้างอิง</div>
                    <div class="col-12 col-md-8">@jobNo </div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">ผู้ขอใช้รถ</div>
                    <div class="col-12 col-md-8 text-muted">@requesterName</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">รหัสพนักงาน</div>
                    <div class="col-12 col-md-8 text-muted">@requesterCode</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">ประเภทการเดินทาง</div>
                    <div class="col-12 col-md-8 text-muted">@tripTypeText</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">ประเภทรถ</div>
                    <div class="col-12 col-md-8 text-muted">@vehicleTypeText</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">ประเภทบริการ</div>
                    <div class="col-12 col-md-8 text-muted">@serviceTypeText</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">จำนวนผู้โดยสาร</div>
                    <div class="col-12 col-md-8 text-muted">@passengers</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">วัตถุประสงค์</div>
                    <div class="col-12 col-md-8 text-muted">@Model.Purpose</div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.DetailNote))
                {
                    <div class="row mb-2">
                        <div class="col-12 col-md-4 fw-semibold">รายละเอียดอื่นๆ</div>
                        <div class="col-12 col-md-8 text-muted">@Model.DetailNote</div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(specialOccasionText))
                {
                    <div class="row mb-2">
                        <div class="col-12 col-md-4 fw-semibold">กรณีพิเศษ</div>
                        <div class="col-12 col-md-8 text-muted">@specialOccasionText</div>
                    </div>
                    if (!string.IsNullOrWhiteSpace(Model.SpecialOccasionRemark))
                    {
                        <div class="row mb-2">
                            <div class="col-12 col-md-4 fw-semibold">หมายเหตุ</div>
                            <div class="col-12 col-md-8 text-muted">@Model.SpecialOccasionRemark</div>
                        </div>
                    }
                }

                @if (Model.Attachments?.Any() == true)
                {
                    <div class="row mb-2">
                        <div class="col-12 col-md-4 fw-semibold">เอกสารเพิ่มเติม</div>
                        <div class="col-12 col-md-8 text-muted">
                            <ul class="list-unstyled mb-0">
                                @foreach (var a in Model.Attachments)
                                {
                                    <li class="mb-1">
                                        <a href="@(Url.Content("~" + a.StoragePath))" target="_blank">@a.FileName</a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
            <div class="vb-card p-3 p-md-4 mb-3">
                <div class="h5 mt-2">รายละเอียดการเดินทาง</div>
                <div class="vb-divider my-3"></div>
                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">สถานที่ต้นทาง</div>
                    <div class="col-12 col-md-8 text-muted">@Model.PickupLocation</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">สถานที่ปลายทาง</div>
                    <div class="col-12 col-md-8 text-muted">@Model.DestinationLocation</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">เวลา</div>
                    <div class="col-12 col-md-8 text-muted">@Model.StartAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm") - @Model.EndAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</div>
                </div>

                <div class="vb-divider my-3"></div>

                @if (external != null)
                {
                    <div class="row mb-2">
                        <div class="col-12 col-md-4 fw-semibold">ผู้ให้บริการ</div>
                        <div class="col-12 col-md-8 text-muted">@external.VendorName</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-12 col-md-4 fw-semibold">ค่าใช้จ่าย</div>
                        <div class="col-12 col-md-8 text-muted">@(external.QuotedPrice?.ToString("C", new CultureInfo("th-TH")) ?? "-")</div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-12 col-md-4 fw-semibold">หมายเหตุ</div>
                        <div class="col-12 col-md-8 text-muted">@(string.IsNullOrWhiteSpace(external.Note) ? "-" : external.Note)</div>
                    </div>
                }

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">ทะเบียนรถ</div>
                    <div class="col-12 col-md-8 text-muted">@vehicleText</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">รายชื่อพนักงานขับรถ</div>
                    <div class="col-12 col-md-8 text-muted">@driverText</div>
                </div>

                <div class="row mb-2">
                    <div class="col-12 col-md-4 fw-semibold">เบอร์โทรพนักงานขับรถ</div>
                    <div class="col-12 col-md-8 text-muted">@driverPhone</div>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6">
            @if (Model.Approvals?.Any() == true)
            {
                var approvals = Model.Approvals
                .OrderBy(x => x.LevelNo)
                .ToList();

                <div class="vb-card approval-section p-3 p-md-4 mb-3">
                    <div class="d-flex justify-content-between">
                        <div class="h5 mt-2">
                            ผู้อนุมัติ
                        </div>
                        <div class="d-flex align-content-center justify-content-end">
                            <span class="vb-status vb-status-draft">
                                @approvals.Count ระดับ
                            </span>
                        </div>
                    </div>

                    <div class="vb-divider my-3"></div>

                    <div class="approval-timeline">
                        @for (var index = 0; index < approvals.Count; index++)
                        {
                            var approval = approvals[index];

                            var approverName =
                            approval.Approver?.UsernameTH
                            ?? approval.Approver?.UsernameEN
                            ?? approval.ApproverUserId.ToString();

                            var actionAt = approval.ActionAtUtc.HasValue
                            ? approval.ActionAtUtc.Value
                            .ToLocalTime()
                            .ToString("dd MMM yyyy HH:mm")
                            : "-";

                            var approvalStatusText = ApprovalStatusText(approval.Status);
                            var approvalBadgeClass = ApprovalBadgeClass(approval.Status);
                            var isLast = index == approvals.Count - 1;

                            <div class="approval-timeline-item">
                                <div class="approval-timeline-marker">
                                    <div class="approval-level-circle @approvalBadgeClass">
                                    </div>

                                    @if (!isLast)
                                    {
                                        <div class="approval-timeline-line"></div>
                                    }
                            </div>

                            <div class="approval-item-card">
                                <div class="approval-item-header">
                                    <div class="min-w-0">
                                        <div class="approval-level-label">
                                            ผู้อนุมัติระดับขั้นที่ @approval.LevelNo
                                        </div>

                                        <div class="approval-name text-break">
                                            @approverName
                                        </div>
                                    </div>

                                    <span class="badge rounded-pill @approvalBadgeClass approval-status-badge">
                                        @approvalStatusText
                                    </span>
                                </div>

                                <div class="approval-details">
                                    <div class="approval-detail-item">
                                        <div class="approval-detail-label">
                                            วันที่ดำเนินการ
                                        </div>
                                        <div class="approval-detail-value">
                                            @actionAt
                                        </div>
                                    </div>

                                    <div class="approval-detail-item approval-comment">
                                        <div class="approval-detail-label">
                                            หมายเหตุ
                                        </div>
                                        <div class="approval-detail-value text-break">
                                            @(string.IsNullOrWhiteSpace(approval.Comment) ? "-" : approval.Comment)
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    }
                    </div>
                </div>
            }
            <div class="vb-card p-3 p-md-4 mb-3">
                @if (Model.Status == VehicleBooking.Web.Domain.Enums.BookingStatus.WaitingAdminVendorQuotation)
                {
                    <div class="h5 mt-2">เสนอผู้ให้บริการ</div>
                    <div class="vb-divider my-3"></div>
                    <form asp-action="SendVendorQuote" asp-route-id="@Model.BookingId" method="post" id="sendVendorQuoteForm" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="mb-2">
                            <label class="form-label">ผู้ให้บริการ <span class="text-danger">*</span></label>
                            <input name="VendorName" class="form-control" required value="@(Model.ExternalRental?.VendorName ?? "")" />
                            <div class="text-danger small mt-1 d-none" data-error-for="VendorName"></div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">ราคา <span class="text-danger">*</span></label>
                            <input name="QuotedPrice" type="number" step="0.01" min="0.01" class="form-control" required value="@(Model.ExternalRental?.QuotedPrice?.ToString() ?? "")" />
                            <div class="text-danger small mt-1 d-none" data-error-for="QuotedPrice"></div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">หมายเหตุ</label>
                            <textarea name="Note" class="form-control">@(Model.ExternalRental?.Note ?? "")</textarea>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-ci" type="submit">ตอบกลับ</button>
                        </div>
                    </form>
                }
                @if (Model.Status == VehicleBooking.Web.Domain.Enums.BookingStatus.WaitingAdminVendorConfirm)
                {
                    <div class="fw-semibold mb-2">รายละเอียดพนักงานขับรถ</div>
                    <form asp-action="ConfirmVendor" asp-route-id="@Model.BookingId" method="post" id="confirmVendorForm" novalidate>
                        @Html.AntiForgeryToken()
                        <div class="mb-2">
                            <label class="form-label">ทะเบียนรถ <span class="text-danger">*</span></label>
                            <input name="RentalPlateNo" class="form-control" required value="@(Model.ExternalRental?.RentalPlateNo ?? "")" />
                            <div class="text-danger small mt-1 d-none" data-error-for="RentalPlateNo"></div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">รายชื่อพนักงานขับรถ <span class="text-danger">*</span></label>
                            <input name="RentalDriverName" class="form-control" required value="@(Model.ExternalRental?.RentalDriverName ?? "")" />
                            <div class="text-danger small mt-1 d-none" data-error-for="RentalDriverName"></div>
                        </div>
                        <div class="mb-2">
                            <label class="form-label">เบอร์โทรพนักงานขับรถ <span class="text-danger">*</span></label>
                            <input name="RentalDriverPhone" class="form-control" required value="@(Model.ExternalRental?.RentalDriverPhone ?? "")" />
                            <div class="text-danger small mt-1 d-none" data-error-for="RentalDriverPhone"></div>
                        </div>
                        <div class="d-flex gap-2 justify-content-end">
                            <button class="btn btn-success" type="submit">Confirm</button>
                        </div>
                    </form>
                }
                @if (Model.CompletionPhotos?.Any() == true)
                {
                    <div class="fw-semibold mb-3">รูปภาพประกอบการจบงาน</div>
                    @foreach (var group in ((IEnumerable<DriverCompletionPhotoGroup>)Enum.GetValues(typeof(DriverCompletionPhotoGroup))))
                    {
                        var groupPhotos = Model.CompletionPhotos.Where(p => p.PhotoGroup == group).ToList();
                        if (!groupPhotos.Any()) continue;
                        <div class="mb-3">
                            <div class="fw-semibold small mb-2">@PhotoGroupLabel(group)</div>
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var photo in groupPhotos)
                                {
                                    <a href="@(Url.Content("~" + photo.RelativePath))" target="_blank" title="@photo.OriginalFileName">
                                        <img src="@(Url.Content("~" + photo.RelativePath))" alt="@photo.OriginalFileName"
                                             style="height:90px;width:90px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6;" />
                                    </a>
                                }
                            </div>
                        </div>
                    }
                }
                @{
                    var isTerminalStatus = VehicleBooking.Web.Domain.Helpers.BookingStatusHelper
                    .TerminalStatuses.Contains(Model.Status);
                    var isPersonalAdminStep = Model.Status == BookingStatus.WaitingAdminPersonal && Model.IsPersonal;
                }

                <div class="vb-divider my-3"></div>

                <div class="d-flex justify-content-end flex-wrap gap-2">
                    @if (isPersonalAdminStep)
                    {
                        <form asp-action="ApprovePersonal" asp-route-id="@Model.BookingId" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-success">อนุมัติรถส่วนตัว</button>
                        </form>
                        <form asp-action="RejectPersonal" asp-route-id="@Model.BookingId" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger">ปฏิเสธรถส่วนตัว</button>
                        </form>
                    }
                    @if (Model.Status == BookingStatus.AdminActionRequired)
                    {
                        <form asp-action="ForceComplete" asp-route-id="@Model.BookingId" method="post">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-success">จบงาน</button>
                        </form>
                    }
                    @* Admin override: allow rejecting the job in any non-terminal step that is not
                       already covered by the admin's own reject step above. *@
                    @if (!isTerminalStatus && !isPersonalAdminStep)
                    {
                        <form asp-action="RejectBooking" asp-route-id="@Model.BookingId" method="post"
                              onsubmit="return confirm('ยืนยันการปฏิเสธใบงานนี้? การดำเนินการนี้ไม่สามารถย้อนกลับได้');">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-outline-danger">ปฏิเสธใบงาน</button>
                        </form>
                    }
                    <a asp-action="AllBookings" class="btn btn-light">
                        ย้อนกลับ
                    </a>
                </div>
            </div>
        </div>
    </div>

    @{
        bool showReassign = ViewBag.ShowReassign is bool sr && sr;
        var availableDrivers = (ViewBag.AvailableDrivers as IEnumerable<SelectListItem>)
                               ?? Enumerable.Empty<SelectListItem>();
    }
    @if (showReassign)
    {
        <div class="vb-card p-3 p-md-4 mb-3">
            <div class="fw-semibold mb-2">เปลี่ยน พขร./รถ</div>
            <div class="text-muted small mb-3">ระบบจะแสดงเฉพาะ พขร./รถ ที่ว่างในช่วงวันและเวลาที่จอง</div>

            <div class="vb-approver-row mb-2">
                <div class="vb-approver-label">พขร./รถ ปัจจุบัน</div>
                <div class="vb-approver-value">@driverText / @vehicleText</div>
            </div>
            <div class="vb-approver-row mb-3">
                <div class="vb-approver-label">ช่วงเวลา</div>
                <div class="vb-approver-value">
                    @Model.StartAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm") – @Model.EndAtUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                </div>
            </div>

            @if (!availableDrivers.Any())
            {
                <div class="text-muted small">ไม่มี พขร./รถ ว่างในช่วงเวลาที่จอง</div>
            }
            else
            {
                <form asp-action="ReassignDriver" asp-route-id="@Model.BookingId" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">เลือก พขร./รถ</label>
                        <select name="driverId" class="form-select">
                            @foreach (var opt in availableDrivers)
                            {
                                if (opt.Selected)
                                {
                                    <option value="@opt.Value" selected>@opt.Text</option>
                                }
                                else
                                {
                                    <option value="@opt.Value">@opt.Text</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-ci">บันทึกการเปลี่ยน พขร./รถ</button>
                    </div>
                </form>
            }
        </div>
    }
</section>

@section Scripts {
<script>
(function () {
    function setError(input, errEl, msg) {
        if (input) input.classList.add('is-invalid');
        if (errEl) { errEl.textContent = msg; errEl.classList.remove('d-none'); }
    }
    function clearError(input, errEl) {
        if (input) input.classList.remove('is-invalid');
        if (errEl) { errEl.textContent = ''; errEl.classList.add('d-none'); }
    }
    function errorEl(form, name) {
        return form.querySelector('[data-error-for="' + name + '"]');
    }

    // ----- SendVendorQuote: vendor required, price required and > 0 -----
    var quoteForm = document.getElementById('sendVendorQuoteForm');
    if (quoteForm) {
        quoteForm.addEventListener('submit', function (e) {
            var vendor = quoteForm.querySelector('[name="VendorName"]');
            var price = quoteForm.querySelector('[name="QuotedPrice"]');
            var firstInvalid = null;

            if (vendor) { vendor.value = vendor.value.trim(); clearError(vendor, errorEl(quoteForm, 'VendorName')); }
            if (price) { price.value = price.value.trim(); clearError(price, errorEl(quoteForm, 'QuotedPrice')); }

            if (vendor && vendor.value === '') {
                setError(vendor, errorEl(quoteForm, 'VendorName'), 'กรุณาเลือกผู้ให้บริการ');
                firstInvalid = firstInvalid || vendor;
            }

            if (price) {
                if (price.value === '') {
                    setError(price, errorEl(quoteForm, 'QuotedPrice'), 'กรุณากรอกราคา');
                    firstInvalid = firstInvalid || price;
                } else {
                    var num = Number(price.value);
                    if (isNaN(num) || num <= 0) {
                        setError(price, errorEl(quoteForm, 'QuotedPrice'), 'ราคาต้องมากกว่า 0');
                        firstInvalid = firstInvalid || price;
                    }
                }
            }

            if (firstInvalid) {
                e.preventDefault();
                e.stopPropagation();
                firstInvalid.focus();
            }
        });
    }

    // ----- ConfirmVendor: plate, driver name, phone all required -----
    var confirmForm = document.getElementById('confirmVendorForm');
    if (confirmForm) {
        confirmForm.addEventListener('submit', function (e) {
            var fields = [
                { name: 'RentalPlateNo', msg: 'กรุณากรอกทะเบียนรถ' },
                { name: 'RentalDriverName', msg: 'กรุณากรอกชื่อผู้ขับ' },
                { name: 'RentalDriverPhone', msg: 'กรุณากรอกเบอร์โทรติดต่อ' }
            ];
            var firstInvalid = null;

            fields.forEach(function (f) {
                var input = confirmForm.querySelector('[name="' + f.name + '"]');
                var el = errorEl(confirmForm, f.name);
                if (!input) return;
                input.value = input.value.trim(); // trim whitespace before checking
                clearError(input, el);
                if (input.value === '') {
                    setError(input, el, f.msg);
                    firstInvalid = firstInvalid || input;
                }
            });

            if (firstInvalid) {
                e.preventDefault();
                e.stopPropagation();
                firstInvalid.focus();
            }
        });
    }
})();
</script>
}
